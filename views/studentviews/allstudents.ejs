<% layout("layouts/boilerplate") -%>
<div class="row mx-auto">
<h1 class="text-center text-white bg-primary">All Students</h1>
<% allstudents.forEach((student)=>{ %>
 <div class="card col-md-4 m-2" style="width: 18rem;">
  <div class="card-body">
    <h5 class="card-title"><%= student.name %></h5>
    <p class="card-text"><%= student.course %></p>
    <a href="http://localhost:8080/api/sms/student/<%= student._id %>" class="btn btn-primary">View</a>
  </div>
 </div>
<% }); %>
</div>
