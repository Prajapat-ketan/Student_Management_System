<% if(success_msg && success_msg.length>0){ %>
      <div class="alert alert-success alert-dismissible fade show position-fixed top-0 end-0 m-2 z-3" role="alert">
        <%= success_msg %>
        <button type="button" class="btn-close " data-bs-dismiss="alert" aria-label="Close">
        </button>
    </div>
   <% }
   
if(error_msg && error_msg.length>0){ %>
     <div class="alert alert-danger alert-dismissible fade show position-fixed top-0 end-0 m-2 z-3" role="alert">
       <%= error_msg %>
       <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
       </button>
    </div>
<% } %>
