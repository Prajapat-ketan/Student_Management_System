<% layout("layouts/boilerplate")-%>
<h1 class=" text-center text-white">User Signin</h1>
    <form class="row g-3 w-25 my-3 mx-auto needs-validation border border-2 border-white p-4 rounded-3" novalidate action="http://localhost:8080/api/sms/user/signin" method="POST">
        <div class="col-12">
            <label for="email" class="form-label">Email</label>
            <input type="email" class="form-control" id="email" placeholder="ketan123@gmail.com" name="user[email]"  required>
            <div class="valid-feedback bg-dark p-1 rounded-2 text-white">
                Looks good!
            </div>
        </div>
        <div class="col-12">
            <label for="password" class="form-label">Password</label>
            <input type="password" class="form-control" id="password" placeholder="ketan123" name="user[password]" required>
            <div class="valid-feedback bg-dark p-1 rounded-2 text-white">
                Looks good!
            </div>
        </div>
        <div class="col-12">
            <button class="btn btn-dark" type="submit">Login</button>
        </div>
    </form>
